<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

  <!-- 🔓 SOLO DESARROLLO (HTTP permitido) -->
  <domain-config cleartextTrafficPermitted="true">
    <!-- <domain includeSubdomains="true">192.168.1.17</domain> -->
    <domain includeSubdomains="true">192.168.110.111</domain>
  </domain-config>

  <!-- 🔐 PRODUCCIÓN (HTTPS obligatorio) -->
  <domain-config cleartextTrafficPermitted="false">
    <domain includeSubdomains="true">api.tudominio.com</domain>
  </domain-config>

</network-security-config>